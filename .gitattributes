# Line endings
* text=auto

# Shell scripts — LF always
*.sh text eol=lf

# Generated files — excluded from diffs and language stats
index.md   linguist-generated=true linguist-documentation=false

# Vendored / config — not counted as code
config.json linguist-language=JSON

# Documentation
*.md linguist-documentation=true
# index.md overrides the *.md rule above (more specific rule wins)
index.md linguist-documentation=false
