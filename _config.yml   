title: "fresh-editor — i686 builds"
description: "Automated builds of Fresh IDE for older 32-bit x86 processors"
url: "https://vapenyk.github.io"
baseurl: "/fresh-i686-build"

# Use kramdown — GitHub Pages default, safe mode
markdown: kramdown
kramdown:
  input: GFM
  hard_wrap: false
  syntax_highlighter: none   # no Rouge — we style pre/code ourselves

# GitHub Pages safe plugins only
plugins:
  - jekyll-seo-tag

# Don't copy these into _site.
# Note: README.md is the source of truth — the generate-site workflow
# reads it and writes index.md, which Jekyll then processes normally.
include: ["README.md"]
exclude:
  - fresh-install.sh
  - config.json
  - "*.yml"
  - Gemfile
  - Gemfile.lock
  - .gitattributes
